# ============================================================
# StadiumMind AI — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional (Render sets these automatically) ────────────────
# Server host — use 0.0.0.0 in production (Render/Docker)
HOST=0.0.0.0

# Server port — Render injects $PORT automatically
PORT=8000

# CORS origins — comma-separated list of allowed frontend URLs
# Use * for open access (not recommended in production)
# Example: https://stadium-mind.vercel.app,https://www.yourdomain.com
CORS_ORIGINS=*

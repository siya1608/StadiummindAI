# ============================================================
# StadiumMind AI — .gitignore
# ============================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env
*.egg
*.egg-info/
dist/
build/
.eggs/

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Environment files (NEVER commit secrets) ---
backend/.env
.env.local
.env.production

# --- ChromaDB vector store (rebuilt on first deploy) ---
backend/data/chroma_db/

# --- IDE & OS ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo
Thumbs.db

# --- Logs ---
*.log
logs/

# --- Node (if any frontend tooling is added) ---
node_modules/
.next/
.vercel/
